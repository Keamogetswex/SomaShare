@model List<SomaShareWebApp.ViewModels.TransactionListItemViewModel>

@{
    ViewData["Title"] = "My Transactions";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>My Transactions</h1>
        </div>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Textbook</th>
                        <th>Amount</th>
                        <th>Payment Method</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var transaction in Model)
                    {
                        <tr>
                            <td>@transaction.TextbookTitle</td>
                            <td>@transaction.Amount.ToString("C")</td>
                            <td>@transaction.PaymentMethod</td>
                            <td>
                                @if (transaction.Status == SomaShareWebApp.Models.Enums.TransactionStatus.Pending)
                                {
                                    <span class="badge bg-warning">Pending</span>
                                }
                                else if (transaction.Status == SomaShareWebApp.Models.Enums.TransactionStatus.InProgress)
                                {
                                    <span class="badge bg-info">In Progress</span>
                                }
                                else if (transaction.Status == SomaShareWebApp.Models.Enums.TransactionStatus.Completed)
                                {
                                    <span class="badge bg-success">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Cancelled</span>
                                }
                            </td>
                            <td>@transaction.CreatedAt.ToString("g")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@transaction.Id" class="btn btn-sm btn-info">
                                    <i class="fas fa-eye"></i> View
                                </a>
                                <a asp-action="Edit" asp-route-id="@transaction.Id" class="btn btn-sm btn-warning">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            You have no transactions yet.
        </div>
    }

    <a asp-controller="Offers" asp-action="Received" class="btn btn-secondary mt-3">
        <i class="fas fa-arrow-left"></i> Back to Offers
    </a>
</div>
