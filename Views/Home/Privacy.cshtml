@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mt-5">
    <div class="bg-light p-5 rounded shadow-sm">
        <h1 class="display-4 text-primary">@ViewData["Title"]</h1>
        <p class="lead">Your privacy, safety and education matters to us. This page explains how SomaShare handles your data according to our values.</p>
    </div>

    
    <div class="mt-4">
        <h3 class="text-success">Data Security</h3>
        <p>We use industry-standard encryption and secure servers to protect your personal information.</p>

        <h3 class="text-info">Information We Collect</h3>
        <p>Basic account details such as your name, email, and university are stored to provide a personalized experience.</p>

        <h3 class="text-warning">How We Use Your Data</h3>
        <p>Your data is used only to facilitate textbook exchanges, offers, and transactions.No third parties involved.</p>

        <h3 class="text-danger">Your Rights</h3>
        <p>You can update or delete your account information at any time. Contact support if you need assistance.</p>
    </div>

    <
    <div class="alert alert-primary mt-5 text-center">
        <strong>Questions?</strong> Reach out to our support team for more details about our privacy practices.
    </div>
</div>

