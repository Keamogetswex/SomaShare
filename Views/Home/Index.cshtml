@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-5">
    <!-- Hero -->
    <div class="text-center bg-light p-5 rounded shadow-sm">
        <h1 class="display-3 fw-bold text-primary">Welcome to SomaShare</h1>
        <p class="lead mt-3">
            A platform created to assist students buy, sell, and exchange textbooks at a reasonable price and at their convenience.
        </p>
        <!-- Corrected buttons -->
        <a class="btn btn-primary btn-lg mt-4" asp-controller="Textbooks" asp-action="Index">
            Browse Textbooks
        </a>
        <a class="btn btn-outline-secondary btn-lg mt-4 ms-2" asp-controller="WantedAds" asp-action="Index">
            Post a Wanted Ad
        </a>
    </div>

    <!-- Features of SomaShare -->
    <div class="row text-center mt-5">
        <div class="col-md-4">
            <i class="bi bi-book display-4 text-primary"></i>
            <h3 class="mt-3">Find Textbooks</h3>
            <p>Search by title, author, ISBN, or course code.</p>
        </div>
        <div class="col-md-4">
            <i class="bi bi-cash-stack display-4 text-success"></i>
            <h3 class="mt-3">Affordable Prices</h3>
            <p>Buy and sell textbooks at student-friendly rates.</p>
        </div>
        <div class="col-md-4">
            <i class="bi bi-people display-4 text-warning"></i>
            <h3 class="mt-3">Trusted Community</h3>
            <p>Build trust with reviews and completed transactions.</p>
        </div>
    </div>
</div>
