@model List<SomaShareWebApp.ViewModels.WantedAdListItemViewModel>

@{
    ViewData["Title"] = "Wanted Ads";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Wanted Ads</h1>
        </div>
        <div class="col-md-4 text-end">
            @if (User.Identity?.IsAuthenticated ?? false)
            {
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Create Wanted Ad
                </a>
            }
        </div>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div class="row">
            @foreach (var ad in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">@ad.Title</h5>
                            <p class="card-text">@ad.Description</p>
                            <p class="card-text">
                                <strong>Max Price:</strong> <span class="text-success">@ad.MaxPrice.ToString("C")</span>
                            </p>
                            @if (!string.IsNullOrEmpty(ad.PreferredCondition))
                            {
                                <p class="card-text">
                                    <strong>Preferred Condition:</strong> @ad.PreferredCondition
                                </p>
                            }
                            <p class="card-text">
                                @if (ad.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactive</span>
                                }
                            </p>
                            <p class="card-text text-muted">
                                <small>Posted by: @ad.BuyerName on @ad.CreatedAt.ToString("g")</small>
                            </p>
                        </div>
                        <div class="card-footer bg-white">
                            <a asp-action="Details" asp-route-id="@ad.Id" class="btn btn-sm btn-primary">
                                <i class="fas fa-eye"></i> View Details
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            No wanted ads found. @if (User.Identity?.IsAuthenticated ?? false)
            {
                <a asp-action="Create">Create one now!</a>
            }
        </div>
    }
</div>
