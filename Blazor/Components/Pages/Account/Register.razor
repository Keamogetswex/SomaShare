<Component /><Component1 />@inject SignInManager<ApplicationUser> SignInManager
@inject EmailValidationService EmailValidation
@inject NavigationManager Navigation
@inject LocalizationService L

<PageTitle>@L["Register"] - @L["AppName"]</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow">
            <div class="card-body p-4">
                <h2 class="text-center mb-4">📚 Join @L["AppName"]</h2>
                <p class="text-center text-muted mb-4">
                    Create an account using your university email
                </p>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="alert alert-danger">@_errorMessage</div>
                }

                <EditForm Model="_model" OnValidSubmit="HandleRegister" FormName="register">
                    <DataAnnotationsValidator />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">First Name *</label>
                            <InputText class="form-control" @bind-Value="_model.FirstName" />
                            <ValidationMessage For="@(() => _model.FirstName)" class="text-danger" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Last Name *</label>
                            <InputText class="form-control" @bind-Value="_model.LastName" />
                            <ValidationMessage For="@(() => _model.LastName)" class="text-danger" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">University Email *</label>
                        <InputText class="form-control" @bind-Value="_model.Email" 
                                   type="email" placeholder="your.email@university.ac.za" />
                        <ValidationMessage For="@(() => _model.Email)" class="text-danger" />
                        <small class="text-muted">@EmailValidation.GetValidationMessage()</small>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">University *</label>
                            <InputText class="form-control" @bind-Value="_model.University" 
                                       placeholder="e.g., University of Lagos" />
                            <ValidationMessage For="@(() => _model.University)" class="text-danger" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Campus *</label>
                            <InputText class="form-control" @bind-Value="_model.Campus" 
                                       placeholder="e.g., Main Campus" />
                            <ValidationMessage For="@(() => _model.Campus)" class="text-danger" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Password *</label>
                            <InputText class="form-control" @bind-Value="_model.Password" type="password" />
                            <ValidationMessage For="@(() => _model.Password)" class="text-danger" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Confirm Password *</label>
                            <InputText class="form-control" @bind-Value="_model.ConfirmPassword" type="password" />
                            <ValidationMessage For="@(() => _model.ConfirmPassword)" class="text-danger" />
                        </div>
                    </div>

                    <small class="text-muted d-block mb-3">
                        Password must be at least 8 characters with uppercase, lowercase, number, and special character.
                    </small>

                    <div class="mb-3 form-check">
                        <InputCheckbox class="form-check-input" @bind-Value="_model.AcceptTerms" />
                        <label class="form-check-label">
                            I accept the <a href="#" target="_blank">Terms of Service</a> and 
                            <a href="#" target="_blank">Privacy Policy</a>
                        </label>
                        <ValidationMessage For="@(() => _model.AcceptTerms)" class="text-danger" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100" disabled="@_isSubmitting">
                        @if (_isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        @L["Register"]
                    </button>
                </EditForm>

                <hr />

                <p class="text-center mb-0">
                    Already have an account? <a href="/Account/Login">Login here</a>
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterModel _model = new();
    private string? _errorMessage;
    private bool _isSubmitting;

    private async Task HandleRegister()
    {
        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            // Validate university email
            if (!EmailValidation.IsValidUniversityEmail(_model.Email))
            {
                _errorMessage = EmailValidation.GetValidationMessage();
                return;
            }

            if (!_model.AcceptTerms)
            {
                _errorMessage = "You must accept the terms and conditions.";
                return;
            }

            var user = new ApplicationUser
            {
                UserName = _model.Email,
                Email = _model.Email,
                FirstName = _model.FirstName,
                LastName = _model.LastName,
                University = _model.University,
                Campus = _model.Campus,
                EmailConfirmed = true // For demo; in production, send confirmation email
            };

            var result = await UserManager.CreateAsync(user, _model.Password);

            if (result.Succeeded)
            {
                // Assign default roles
                await UserManager.AddToRolesAsync(user, new[] { "Buyer", "Seller" });

                // Sign in
                await SignInManager.SignInAsync(user, isPersistent: false);
                Navigation.NavigateTo("/dashboard", forceLoad: true);
            }
            else
            {
                _errorMessage = string.Join(" ", result.Errors.Select(e => e.Description));
            }
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private class RegisterModel
    {
        [Required(ErrorMessage = "First name is required")]
        [MaxLength(100)]
        public string FirstName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Last name is required")]
        [MaxLength(100)]
        public string LastName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email format")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "University is required")]
        [MaxLength(200)]
        public string University { get; set; } = string.Empty;

        [Required(ErrorMessage = "Campus is required")]
        [MaxLength(100)]
        public string Campus { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please confirm your password")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match")]
        public string ConfirmPassword { get; set; } = string.Empty;

        [Range(typeof(bool), "true", "true", ErrorMessage = "You must accept the terms")]
        public bool AcceptTerms { get; set; }
    }
}
