@page "/textbooks/{Id:int}"
@inject ITextbookService TextbookService
@inject IOfferService OfferService
@inject LocalizationService L
@inject NavigationManager Navigation
@attribute [Authorize]

<PageTitle>Textbook Details - @L["AppName"]</PageTitle>

@if (_textbook == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">@L["Loading"]</span>
        </div>
    </div>
}
else
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item"><a href="/textbooks">Textbooks</a></li>
            <li class="breadcrumb-item active" aria-current="page">@_textbook.Title</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-5">
            @if (!string.IsNullOrEmpty(_textbook.ImageUrl))
            {
                <img src="@_textbook.ImageUrl" class="img-fluid rounded shadow" alt="@_textbook.Title">
            }
            else
            {
                <div class="bg-light rounded d-flex align-items-center justify-content-center" 
                     style="height: 400px;">
                    <span class="display-1 text-muted">📚</span>
                </div>
            }
        </div>
        
        <div class="col-md-7">
            <h1>@_textbook.Title</h1>
            <p class="lead text-muted">by @_textbook.Author</p>

            <div class="mb-3">
                <span class="h2 text-primary">R @_textbook.Price.ToString("N2")</span>
                <span class="badge @GetConditionBadgeClass() ms-2 fs-6">@_textbook.Condition</span>
            </div>

            <table class="table table-borderless">
                <tbody>
                    @if (!string.IsNullOrEmpty(_textbook.ISBN))
                    {
                        <tr>
                            <th scope="row" style="width: 150px;">ISBN</th>
                            <td>@_textbook.ISBN</td>
                        </tr>
                    }
                    @if (!string.IsNullOrEmpty(_textbook.CourseCode))
                    {
                        <tr>
                            <th scope="row">Course Code</th>
                            <td>@_textbook.CourseCode</td>
                        </tr>
                    }
                    <tr>
                        <th scope="row">@L["Campus"]</th>
                        <td>@_textbook.Campus</td>
                    </tr>
                    <tr>
                        <th scope="row">Listed</th>
                        <td>@_textbook.CreatedAt.ToString("dd MMM yyyy")</td>
                    </tr>
                </tbody>
            </table>

            @if (!string.IsNullOrEmpty(_textbook.Description))
            {
                <h5>Description</h5>
                <p>@_textbook.Description</p>
            }

            <!-- Seller Info -->
            @if (_textbook.Seller != null)
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title">Seller Information</h5>
                        <p class="mb-1">
                            <strong>@_textbook.Seller.FirstName @_textbook.Seller.LastName</strong>
                        </p>
                        <p class="mb-1">
                            ⭐ @L["TrustScore"]: <strong>@_textbook.Seller.TrustScore.ToString("0.0")</strong>/5.0
                        </p>
                        <p class="mb-0 text-muted">
                            ✓ @_textbook.Seller.CompletedTransactions @L["CompletedTransactions"]
                        </p>
                    </div>
                </div>
            }

            <!-- Make Offer Form (only if not the seller) -->
            <AuthorizeView>
                <Authorized>
                    @if (_textbook.SellerId != _currentUserId && _textbook.IsAvailable)
                    {
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title">@L["MakeOffer"]</h5>
                                
                                @if (!string.IsNullOrEmpty(_errorMessage))
                                {
                                    <div class="alert alert-danger">@_errorMessage</div>
                                }
                                @if (!string.IsNullOrEmpty(_successMessage))
                                {
                                    <div class="alert alert-success">@_successMessage</div>
                                }

                                <EditForm Model="_offerModel" OnValidSubmit="SubmitOffer">
                                    <DataAnnotationsValidator />
                                    
                                    <div class="mb-3">
                                        <label class="form-label">Offer Amount (R)</label>
                                        <InputNumber class="form-control" @bind-Value="_offerModel.OfferAmount" />
                                        <ValidationMessage For="@(() => _offerModel.OfferAmount)" />
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label class="form-label">Message (Optional)</label>
                                        <InputTextArea class="form-control" @bind-Value="_offerModel.Message" rows="3"
                                                      placeholder="Add a message to the seller..." />
                                    </div>
                                    
                                    <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">
                                        @if (_isSubmitting)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2"></span>
                                        }
                                        @L["MakeOffer"]
                                    </button>
                                </EditForm>
                            </div>
                        </div>
                    }
                    else if (_textbook.SellerId == _currentUserId)
                    {
                        <div class="d-flex gap-2">
                            <a href="/textbooks/edit/@_textbook.Id" class="btn btn-outline-primary">
                                ✏️ @L["Edit"]
                            </a>
                            <button class="btn btn-outline-danger" @onclick="ShowDeleteConfirm">
                                🗑️ @L["Delete"]
                            </button>
                        </div>
                    }
                </Authorized>
            </AuthorizeView>
        </div>
    </div>

    <!-- Offers Section (for seller only) -->
    @if (_textbook.SellerId == _currentUserId && _textbook.Offers.Any())
    {
        <hr class="my-4" />
        
        <h3>Offers Received</h3>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Buyer</th>
                        <th>Amount</th>
                        <th>Message</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var offer in _textbook.Offers.OrderByDescending(o => o.CreatedAt))
                    {
                        <tr>
                            <td>
                                @offer.Buyer.FirstName @offer.Buyer.LastName
                                <br />
                                <small class="text-muted">⭐ @offer.Buyer.TrustScore.ToString("0.0")</small>
                            </td>
                            <td>R @offer.OfferAmount.ToString("N2")</td>
                            <td>@(offer.Message ?? "-")</td>
                            <td>@offer.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>
                                <span class="badge @GetOfferStatusBadge(offer.Status)">@offer.Status</span>
                            </td>
                            <td>
                                @if (offer.Status == OfferStatus.Pending)
                                {
                                    <button class="btn btn-sm btn-success me-1" 
                                            @onclick="() => AcceptOffer(offer.Id)">
                                        @L["AcceptOffer"]
                                    </button>
                                    <button class="btn btn-sm btn-danger" 
                                            @onclick="() => RejectOffer(offer.Id)">
                                        @L["RejectOffer"]
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

<!-- Delete Confirmation Modal -->
@if (_showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@L["Confirm"] Delete</h5>
                    <button type="button" class="btn-close" @onclick="() => _showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this textbook listing?</p>
                    <p class="text-danger">This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _showDeleteModal = false">@L["Cancel"]</button>
                    <button class="btn btn-danger" @onclick="DeleteTextbook">@L["Delete"]</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private Textbook? _textbook;
    private string? _currentUserId;
    private OfferModel _offerModel = new();
    private bool _isSubmitting;
    private string? _errorMessage;
    private string? _successMessage;
    private bool _showDeleteModal;

    protected override async Task OnInitializedAsync()
    {
        _textbook = await TextbookService.GetTextbookByIdAsync(Id);
        
        if (AuthState != null)
        {
            var authState = await AuthState;
            _currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        }

        if (_textbook != null)
        {
            _offerModel.OfferAmount = _textbook.Price;
        }
    }

    private async Task SubmitOffer()
    {
        if (_textbook == null || string.IsNullOrEmpty(_currentUserId)) return;

        _isSubmitting = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            var offer = new Offer
            {
                TextbookId = _textbook.Id,
                BuyerId = _currentUserId,
                OfferAmount = _offerModel.OfferAmount,
                Message = _offerModel.Message
            };

            await OfferService.CreateOfferAsync(offer);
            _successMessage = "Your offer has been submitted successfully!";
            _offerModel = new OfferModel { OfferAmount = _textbook.Price };
        }
        catch (InvalidOperationException ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task AcceptOffer(int offerId)
    {
        if (string.IsNullOrEmpty(_currentUserId)) return;

        try
        {
            await OfferService.AcceptOfferAsync(offerId, _currentUserId);
            Navigation.NavigateTo($"/transactions/create/{offerId}");
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private async Task RejectOffer(int offerId)
    {
        if (string.IsNullOrEmpty(_currentUserId)) return;

        try
        {
            await OfferService.RejectOfferAsync(offerId, _currentUserId);
            _textbook = await TextbookService.GetTextbookByIdAsync(Id);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private void ShowDeleteConfirm() => _showDeleteModal = true;

    private async Task DeleteTextbook()
    {
        if (_textbook == null || string.IsNullOrEmpty(_currentUserId)) return;

        try
        {
            await TextbookService.DeleteTextbookAsync(_textbook.Id, _currentUserId);
            Navigation.NavigateTo("/textbooks");
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _showDeleteModal = false;
        }
    }

    private string GetConditionBadgeClass() => _textbook?.Condition switch
    {
        TextbookCondition.New => "bg-success",
        TextbookCondition.LikeNew => "bg-info",
        TextbookCondition.Good => "bg-primary",
        TextbookCondition.Fair => "bg-warning text-dark",
        TextbookCondition.Poor => "bg-secondary",
        _ => "bg-secondary"
    };

    private string GetOfferStatusBadge(OfferStatus status) => status switch
    {
        OfferStatus.Pending => "bg-warning text-dark",
        OfferStatus.Accepted => "bg-success",
        OfferStatus.Rejected => "bg-danger",
        OfferStatus.Withdrawn => "bg-secondary",
        _ => "bg-secondary"
    };

    private class OfferModel
    {
        [Required]
        [Range(1, 100000, ErrorMessage = "Offer amount must be between R1 and R100,000")]
        public decimal OfferAmount { get; set; }
        
        [MaxLength(500)]
        public string? Message { get; set; }
    }
}

