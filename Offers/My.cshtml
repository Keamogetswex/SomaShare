@model List<SomaShareSS3.ViewModels.OfferListItemViewModel>

@{
    ViewData["Title"] = "My Offers";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>My Offers</h1>
            <p class="text-muted">Offers you have made on textbooks</p>
        </div>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Textbook</th>
                        <th>Listing Price</th>
                        <th>Offer Amount</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var offer in Model)
                    {
                        <tr>
                            <td>@offer.TextbookTitle</td>
                            <td>@offer.ListingPrice.ToString("C")</td>
                            <td>@offer.OfferAmount.ToString("C")</td>
                            <td>
                                @if (offer.Status == SomaShareSS3.Models.Enums.OfferStatus.Pending)
                                {
                                    <span class="badge bg-warning">Pending</span>
                                }
                                else if (offer.Status == SomaShareSS3.Models.Enums.OfferStatus.Accepted)
                                {
                                    <span class="badge bg-success">Accepted</span>
                                }
                                else if (offer.Status == SomaShareSS3.Models.Enums.OfferStatus.Rejected)
                                {
                                    <span class="badge bg-danger">Rejected</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Withdrawn</span>
                                }
                            </td>
                            <td>@offer.CreatedAt.ToString("g")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@offer.Id" class="btn btn-sm btn-info">
                                    <i class="fas fa-eye"></i> View
                                </a>
                                @if (offer.Status == SomaShareSS3.Models.Enums.OfferStatus.Pending)
                                {
                                    <form asp-action="Withdraw" asp-route-id="@offer.Id" method="post" style="display:inline;">
                                        <button type="submit" class="btn btn-sm btn-warning" onclick="return confirm('Withdraw this offer?');">
                                            <i class="fas fa-times"></i> Withdraw
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            You haven't made any offers yet.
        </div>
    }

    <a asp-controller="Textbooks" asp-action="Index" class="btn btn-secondary mt-3">
        <i class="fas fa-arrow-left"></i> Back to Textbooks
    </a>
</div>
