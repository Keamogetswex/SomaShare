@model SomaShareSS3.ViewModels.PaymentMethodViewModel

@{
    ViewData["Title"] = "Payment Method Details";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <h1>Payment Method Details</h1>
            <hr />

            @if (Model != null)
            {
                <div class="card">
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-sm-3">
                                <h6 class="mb-0">ID</h6>
                            </div>
                            <div class="col-sm-9 text-secondary">
                                @Model.Id
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-sm-3">
                                <h6 class="mb-0">Method Name</h6>
                            </div>
                            <div class="col-sm-9 text-secondary">
                                @Model.Name
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                        <i class="fas fa-edit"></i> Edit
                    </a>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                </div>
            }
            else
            {
                <div class="alert alert-danger">
                    Payment method not found.
                </div>
            }
        </div>
    </div>
</div>
