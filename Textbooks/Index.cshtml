@model List<SomaShareSS3.ViewModels.TextbookListItemViewModel>

@{
    ViewData["Title"] = "Textbooks";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Textbooks</h1>
        </div>
        <div class="col-md-4 text-end">
            @if (User.Identity?.IsAuthenticated ?? false)
            {
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus"></i> List New Textbook
                </a>
            }
        </div>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div class="row">
            @foreach (var textbook in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        @if (!string.IsNullOrEmpty(textbook.ImageUrl))
                        {
                            <img src="@textbook.ImageUrl" class="card-img-top" alt="@textbook.Title" style="height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="card-img-top bg-secondary" style="height: 200px; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-book text-white" style="font-size: 3rem;"></i>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title">@textbook.Title</h5>
                            <p class="card-text text-muted">by @textbook.Author</p>
                            @if (!string.IsNullOrEmpty(textbook.CourseCode))
                            {
                                <p class="card-text">
                                    <strong>Course:</strong> @textbook.CourseCode
                                </p>
                            }
                            <p class="card-text">
                                <strong>Campus:</strong> @textbook.Campus
                            </p>
                            <p class="card-text">
                                <strong>Price:</strong> <span class="text-success">@textbook.Price.ToString("C")</span>
                            </p>
                            <p class="card-text">
                                <span class="badge bg-info">@textbook.Condition</span>
                                @if (textbook.IsAvailable)
                                {
                                    <span class="badge bg-success">Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Unavailable</span>
                                }
                            </p>
                            <p class="card-text text-muted">
                                <small>Seller: @textbook.SellerName</small>
                            </p>
                        </div>
                        <div class="card-footer bg-white">
                            <a asp-action="Details" asp-route-id="@textbook.Id" class="btn btn-sm btn-primary">
                                <i class="fas fa-eye"></i> View Details
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            No textbooks found. @if (User.Identity?.IsAuthenticated ?? false)
            {
                <a asp-action="Create">List one now!</a>
            }
        </div>
    }
</div>
